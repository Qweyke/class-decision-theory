import numpy as np


class TransportationSolver:
    def __init__(self, costs, supply, demand):
        self.c = np.array(costs, dtype=float)
        self.a = np.array(supply, dtype=float)
        self.b = np.array(demand, dtype=float)
        self.m, self.n = self.c.shape
        self.x = np.zeros((self.m, self.n))  # Матрица перевозок

    def initial_plan_nw_corner(self):
        """Метод Северо-Западного угла"""
        a_temp = self.a.copy()
        b_temp = self.b.copy()
        i, j = 0, 0
        while i < self.m and j < self.n:
            grab = min(a_temp[i], b_temp[j])
            self.x[i, j] = grab
            a_temp[i] -= grab
            b_temp[j] -= grab
            if a_temp[i] == 0:
                i += 1
            else:
                j += 1
        print("Начальный план (СЗ-угол):\n", self.x)

    def get_potentials(self):
        """Расчет u_i и v_j по занятым клеткам (u_i + v_j = c_ij)"""
        u = np.full(self.m, None)
        v = np.full(self.n, None)
        u[0] = 0  # Задаем начальный потенциал

        while None in u or None in v:
            for i in range(self.m):
                for j in range(self.n):
                    if self.x[i, j] > 0:  # Если клетка занята
                        if u[i] is not None and v[j] is None:
                            v[j] = self.c[i, j] - u[i]
                        elif v[j] is not None and u[i] is None:
                            u[i] = self.c[i, j] - v[j]
        return u.astype(float), v.astype(float)

    def solve(self):
        self.initial_plan_nw_corner()

        step = 1
        while True:
            u, v = self.get_potentials()

            # Считаем оценки для пустых клеток: Delta = u + v - c
            deltas = np.zeros((self.m, self.n))
            max_delta = -1e-9
            pivot_cell = None

            for i in range(self.m):
                for j in range(self.n):
                    if self.x[i, j] == 0:
                        deltas[i, j] = u[i] + v[j] - self.c[i, j]
                        if deltas[i, j] > max_delta:
                            max_delta = deltas[i, j]
                            pivot_cell = (i, j)

            if max_delta <= 0:
                print("\nОптимальный план найден!")
                break

            print(f"\nШаг {step}: Улучшаем клетку {pivot_cell} с оценкой {max_delta}")
            # В реальном методе потенциалов здесь должен быть поиск цикла (Cycle finder)
            # и переброска груза. Для лабы проще всего показать расчет первого шага.
            # Для полной автоматизации нужен рекурсивный поиск контура.
            break  # Остановимся на расчете оценок для демонстрации


